# Mock tender portals (Railway service mock-sites/).
# Local dev defaults to the Fastify static server on :3002.
# Production: set to the Railway public URL of the mock-sites service,
# e.g. https://bidderly-mock-sites.up.railway.app
MOCK_TENDER_BASE_URL="http://localhost:3002"
